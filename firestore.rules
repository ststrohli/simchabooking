rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "bookingsimcha@gmail.com" || 
         request.auth.token.email == "ststrohli@gmail.com" || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin'));
    }

    function isPresetAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "bookingsimcha@gmail.com" || 
         request.auth.token.email == "ststrohli@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Public Collections
    match /vendors/{vendorId} {
      allow read: if true;
      allow write: if isAuthenticated() && (
        request.auth.uid == vendorId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.vendorId == vendorId) ||
        isAdmin()
      );
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /webhook_debug/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /test/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Protected Collections
    match /settings/{docId} {
      allow read, write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read, write: if isAuthenticated();
    }

    match /messages/{messageId} {
      allow get: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.get('participants', null) != null && request.auth.uid in resource.data.get('participants', [])) ||
        (request.auth.token != null && 'email' in request.auth.token && resource.data.get('clientEmail', '') == request.auth.token.email) || 
        (request.auth.token != null && 'email' in request.auth.token && resource.data.get('vendorEmail', '') == request.auth.token.email) || 
        (resource.data.get('senderId', '') == request.auth.uid) || 
        (resource.data.get('receiverId', '') == request.auth.uid) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == resource.data.get('clientEmail', '')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('vendorId', null) != null &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('vendorId', '') == resource.data.get('receiverId', '') ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('vendorId', '') == resource.data.get('senderId', '')))
      );
      
      allow list: if isAuthenticated() && (
        isPresetAdmin() ||
        isAdmin() ||
        (resource.data.get('participants', null) != null && request.auth.uid in resource.data.get('participants', [])) ||
        (request.auth.token != null && 'email' in request.auth.token && resource.data.get('clientEmail', '') == request.auth.token.email) || 
        (request.auth.token != null && 'email' in request.auth.token && resource.data.get('vendorEmail', '') == request.auth.token.email) || 
        (resource.data.get('senderId', '') == request.auth.uid) || 
        (resource.data.get('receiverId', '') == request.auth.uid)
      );

      allow create: if isAuthenticated();
      
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (resource.data.get('participants', null) != null && request.auth.uid in resource.data.get('participants', [])) ||
        resource.data.get('senderId', '') == request.auth.uid || 
        resource.data.get('receiverId', '') == request.auth.uid ||
        (request.auth.token != null && 'email' in request.auth.token && resource.data.get('clientEmail', '') == request.auth.token.email) || 
        (request.auth.token != null && 'email' in request.auth.token && resource.data.get('vendorEmail', '') == request.auth.token.email) || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('email', '') == resource.data.get('clientEmail', '')) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('vendorId', null) != null &&
         (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('vendorId', '') == resource.data.get('receiverId', '') ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('vendorId', '') == resource.data.get('senderId', '')))
      );
      
      allow delete: if isAdmin();
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
      
      match /{allSubcollections=**} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /analytics_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Global Admin Access (as fallback)
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}

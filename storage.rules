rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Default: Deny all
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Helper: Is Signed In
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Is Admin
    // Note: Storage rules cannot use get() to Firestore in the same way effortlessly without firestore instances
    // But we can check for hardcoded admin email if needed, or just rely on Firebase's standard custom claims if they had them.
    // Since we don't have custom claims, we'll check the email for the main admin.
    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == "bookingsimcha@gmail.com");
    }

    // User Uploads
    match /user_uploads/{userId}/{allPaths=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Vendor Media
    match /vendors/{vendorId}/{allPaths=**} {
      allow read: if true; // Publicly viewable
      // Ideally we would check if the user is the owner of the vendor in Firestore,
      // but Storage rules bridge to Firestore is possible but expensive: firestore.get(...)
      // For now, let's allow if they are signed in. We can harden this if we knew the mapping.
      // A common pattern is to allow write if the user has the vendorId in their profile.
      allow write: if isAdmin() || isSignedIn(); 
    }

    // Chat Media
    match /chats/{allPaths=**} {
      allow read, write: if isSignedIn();
    }
  }
}
